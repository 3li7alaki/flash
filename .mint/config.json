{
	"stack": "typescript",
	"packageManager": "bun",
	"gates": {
		"lint": "bun run lint",
		"types": "bun run types",
		"tests": "bun test",
		"coverage": false
	},
	"reviewers": {
		"spec": {
			"enabled": true,
			"model": "opus"
		},
		"quality": {
			"enabled": true,
			"model": "sonnet"
		},
		"security": {
			"enabled": true,
			"model": "sonnet"
		},
		"conventions": {
			"enabled": true,
			"model": "haiku"
		},
		"tests": {
			"enabled": true,
			"model": "sonnet"
		},
		"business": {
			"enabled": true,
			"model": "opus"
		},
		"performance": {
			"enabled": false
		}
	},
	"conventions": {
		"docs": ["CONTRIBUTING.md", "docs/adr/", "biome.json"]
	},
	"business": {
		"docs": ["PRODUCT.md"]
	},
	"tdd": {
		"default": true,
		"desloppify": true,
		"coverageThreshold": 80
	},
	"instincts": {
		"enabled": true
	},
	"modelRouting": {
		"enabled": true,
		"override": {}
	},
	"autoCommit": true,
	"hooks": {
		"testOnSave": false
	},
	"definitionOfDone": {
		"gatesPassing": true,
		"specReviewPassed": true,
		"stage2ReviewsPassed": true,
		"docCheckPassed": true,
		"screenshotReminder": false
	},
	"isolation": {
		"plan": "worktree",
		"ship": "worktree",
		"quick": "branch"
	},
	"browser": {
		"enabled": false
	},
	"context": {
		"enabled": true,
		"autoRoute": true,
		"sandbox": {
			"timeout": 30000
		},
		"session": {
			"enabled": true
		}
	},
	"design": {
		"enabled": false
	},
	"signature": true,
	"repoMode": "solo",
	"challenge": "auto",
	"reviewScaling": true,
	"parallel": {
		"concurrency": 3,
		"maxBudgetPerSpec": 5
	},
	"plugins": [],
	"mintVersion": "0.8.5",
	"lastUpdated": "2026-04-16T19:34:10.003Z",
	"appliedMigrations": ["0.7.6-to-0.8.0", "0.8.4-to-0.8.5"]
