{
	"stack": "typescript",
	"packageManager": "bun",
	"gates": {
		"lint": "bun run lint",
		"types": "bun run types",
		"tests": "bun test"
	},
	"reviewers": {
		"spec": {
			"enabled": true,
			"model": "opus"
		},
		"quality": {
			"enabled": true,
			"model": "sonnet"
		},
		"security": {
			"enabled": true,
			"model": "sonnet"
		},
		"conventions": {
			"enabled": true,
			"model": "haiku"
		},
		"tests": {
			"enabled": true,
			"model": "sonnet"
		},
		"business": {
			"enabled": true,
			"model": "opus"
		},
		"performance": false
	},
	"conventions": {
		"docs": ["CONTRIBUTING.md", "docs/adr/"]
	},
	"business": {
		"docs": ["PRODUCT.md"]
	},
	"tdd": {
		"default": true,
		"coverageThreshold": 80
	},
	"definitionOfDone": {
		"docCheckPassed": true
	},
	"isolation": {
		"plan": "worktree",
		"ship": "worktree",
		"quick": "branch"
	},
	"signature": true,
	"documenters": [],
	"plugins": [],
	"instincts": {
		"enabled": true
	},
	"modelRouting": {
		"enabled": true,
		"override": {}
	}
}
